@model WebApplication2.Models.UserProfileViewModel
@{
    ViewData["Title"] = "Min profil";
    var fulfilledDealsTableModel = new WebApplication2.Models.UserHubSpotDealTableViewModel
    {
        DetailRowPrefix = "fulfilled-deal-detail",
        EmptyMessage = "Inga uppfyllda affärer importerade för den här perioden ännu.",
        Deals = Model.SelectedPeriodDeals
    };
    var lostDealsTableModel = new WebApplication2.Models.UserHubSpotDealTableViewModel
    {
        DetailRowPrefix = "lost-deal-detail",
        EmptyMessage = "Inga förlorade affärer med kundstatus annullerat, winback eller säljare hittades för den här perioden.",
        Deals = Model.SelectedPeriodLostDeals
    };
}

<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - STL Forum</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <style>
        :root {
            --profile-accent: #0d6efd;
            --profile-accent-soft: #eaf3ff;
            --profile-heading: #123b68;
            --money-color: #0f7a45;
            --provision-color: #7a2ff2;
        }

        .body2 {
            background-color: #f8f9fa;
            margin: 0;
            padding: 0;
        }

        .navbar {
            position: absolute !important;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            padding: 10px 20px !important;
            background: linear-gradient(180deg, rgba(7, 57, 105, 0.56) 0%, rgba(7, 57, 105, 0.18) 65%, rgba(7, 57, 105, 0) 100%);
            backdrop-filter: blur(3px);
        }

        .page-nav-controls {
            gap: 0.5rem;
            position: relative;
            z-index: 1;
            margin-left: auto;
        }

        .hero-image {
            background-image: url('@Url.Content("~/images/herobild.png")');
            height: 35vh;
            background-position: center;
            background-repeat: no-repeat;
            background-size: cover;
            display: flex;
            align-items: center;
            justify-content: center;
            padding-top: 104px;
        }

        .hero-text {
            text-align: center;
            color: white;
            padding: 20px;
        }

        .navbar-brand img {
            transition: transform 0.3s ease;
        }

        .navbar-brand:hover img {
            transform: scale(1.1);
        }

        .deal-summary-row {
            cursor: pointer;
            transition: background-color 0.2s ease;
        }

        .deal-summary-row:hover {
            background-color: #eef4ff !important;
        }

        .deal-summary-row[aria-expanded="true"] {
            background-color: var(--profile-accent-soft) !important;
        }

        .deal-table {
            border-radius: 10px;
            overflow: hidden;
        }

        .deal-table thead th {
            background-color: #ddeeff;
            color: var(--profile-heading);
            font-weight: 700;
            border-bottom: 0;
        }

        .period-toggle-group {
            gap: 0.75rem;
        }

        .period-toggle-group .btn {
            min-width: 170px;
        }

        .profile-period-header {
            margin-bottom: 2.5rem;
        }

        .amount-cell {
            color: var(--money-color);
            font-weight: 700;
        }

        .provision-cell {
            color: var(--provision-color);
            font-weight: 700;
        }

        .status-pill {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 700;
            line-height: 1.1;
            background: #edf1f7;
            color: #344052;
        }

        .status-pill.status-klar {
            background: #dff5e8;
            color: #0f7a45;
        }

        .status-pill.status-ombokning {
            background: #ffeccf;
            color: #9a5d00;
        }

        .status-pill.status-bokad {
            background: #dcedff;
            color: #1f5ca8;
        }

        .status-pill.status-nyregistrerad {
            background: #ede4ff;
            color: #6441c4;
        }

        .status-pill.status-lost {
            background: #fde4e4;
            color: #b42318;
        }

        .deal-detail-card {
            background: linear-gradient(180deg, #ffffff 0%, #f5f9ff 100%);
            border-color: #d9e9ff !important;
        }

        .deal-detail-layout {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1rem;
        }

        .deal-detail-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.6rem;
        }

        .deal-detail-field {
            background: #ffffff;
            border: 1px solid #d9e9ff;
            border-radius: 8px;
            padding: 0.55rem 0.65rem;
            min-width: 0;
        }

        .deal-detail-field.wide {
            grid-column: 1 / -1;
        }

        .deal-products {
            background: #ffffff;
            border: 1px solid #d9e9ff;
            border-radius: 8px;
            padding: 0.7rem 0.8rem;
        }

        .deal-products ul {
            margin-bottom: 0;
            padding-left: 1rem;
        }

        @@media (max-width: 991.98px) {
            .navbar {
                position: absolute !important;
                background: linear-gradient(180deg, rgba(7, 57, 105, 0.72) 0%, rgba(7, 57, 105, 0.3) 65%, rgba(7, 57, 105, 0) 100%);
                backdrop-filter: blur(3px);
                padding: 10px 12px !important;
                align-items: center !important;
                gap: 10px;
            }

            .page-nav-controls {
                width: 100%;
                display: flex;
                flex-wrap: wrap;
                justify-content: center;
                order: 2;
                margin-left: 0;
            }

            .page-nav-controls .btn {
                flex: 0 0 auto;
                min-width: 120px;
            }

            .hero-image {
                height: auto;
                min-height: 28vh;
                padding: 116px 12px 18px;
            }

            .hero-text {
                width: 100%;
                padding: 8px 4px;
            }
        }

        @@media (min-width: 992px) {
            .deal-detail-layout {
                grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
            }

            .deal-detail-grid {
                grid-template-columns: repeat(3, minmax(0, 1fr));
            }
        }

        @@media (max-width: 767.98px) {
            .mobile-hide-col {
                display: none;
            }

            .deal-detail-grid {
                grid-template-columns: repeat(3, minmax(0, 1fr));
                gap: 0.45rem;
            }

            .deal-table th,
            .deal-table td {
                font-size: 0.84rem;
                padding: 0.45rem 0.35rem;
            }

            .status-pill {
                font-size: 0.72rem;
                padding: 2px 8px;
            }

            .deal-detail-field {
                padding: 0.45rem 0.5rem;
            }

            .deal-detail-field .amount-cell,
            .deal-detail-field .provision-cell {
                font-size: 0.86rem;
                line-height: 1.2;
            }
        }

        @@media (max-width: 575.98px) {
            .navbar-brand img {
                height: 42px;
            }
        }
    </style>
</head>
<body class="body2">
<header>
    <nav class="navbar navbar-light justify-content-between center-logo-navbar">
        <a href="@Url.Action("Index", "Social")" class="navbar-brand">
            <img src="~/images/stl-loga.png" width="auto" height="50" alt="STL Logga">
        </a>
        <div class="d-flex align-items-center page-nav-controls">
            <a href="@Url.Action("Logout", "Home")" class="btn btn-danger btn-sm">Sign out</a>
        </div>
    </nav>
    <div class="hero-image">
        <div class="hero-text">
            <h2><b>Min profil</b></h2>
            <p class="mb-0">@Model.Username</p>
        </div>
    </div>
</header>

<main>
    <div class="container my-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between period-toggle-group profile-period-header">
                            <a asp-action="Profile"
                               asp-route-monthOffset="@WebApplication2.Models.UserProfileViewModel.PreviousMonthOffset"
                               class="btn @(Model.IsPreviousMonthSelected ? "btn-primary" : "btn-outline-primary")">
                                Föregående månad
                            </a>
                            <div class="flex-grow-1 text-md-center">
                                <h5 class="mb-1">Uppfyllda affärer för @Model.SelectedPeriodLabel</h5>
                                <p class="text-muted mb-0">Visar affärer för säljare <strong>@Model.Username</strong>.</p>
                            </div>
                            <a asp-action="Profile"
                               asp-route-monthOffset="@WebApplication2.Models.UserProfileViewModel.CurrentMonthOffset"
                               class="btn @(Model.IsCurrentMonthSelected ? "btn-primary" : "btn-outline-primary")">
                                Aktuell månad
                            </a>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-sm-6">
                                <div class="p-3 border rounded bg-light">
                                    <div class="text-muted">Antal affärer under perioden</div>
                                    <div class="fs-4 fw-bold">@Model.SelectedPeriodFulfilledDealsCount</div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="p-3 border rounded bg-light">
                                    <div class="text-muted">Estimerad totalsumma under perioden</div>
                                    <div class="fs-4 fw-bold">@Model.SelectedPeriodFulfilledDealsAmount.ToString("N2")</div>
                                </div>
                            </div>
                        </div>

                        <partial name="_HubSpotDealTable" model="fulfilledDealsTableModel" />

                        <div class="mt-4">
                            <h5 class="mb-2">Lost deals för @Model.SelectedPeriodLabel</h5>
                            <partial name="_HubSpotDealTable" model="lostDealsTableModel" />
                        </div>

                        <div class="mt-4">
                            <a asp-controller="Social" asp-action="Index" class="btn btn-primary">Till startsidan</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const rows = document.querySelectorAll(".deal-summary-row");
        for (const row of rows) {
            const toggleDetails = function () {
                const detailId = row.getAttribute("data-detail-id");
                if (!detailId) {
                    return;
                }

                const detailRow = document.getElementById(detailId);
                if (!detailRow) {
                    return;
                }

                const isExpanded = row.getAttribute("aria-expanded") === "true";
                row.setAttribute("aria-expanded", isExpanded ? "false" : "true");
                detailRow.classList.toggle("d-none");
            };

            row.addEventListener("click", function (event) {
                if (event.target.closest("a, button, input, select, textarea")) {
                    return;
                }

                toggleDetails();
            });

            row.addEventListener("keydown", function (event) {
                if (event.key !== "Enter" && event.key !== " ") {
                    return;
                }

                event.preventDefault();
                toggleDetails();
            });
        }
    });
</script>
</body>
</html>
