@{
ViewData["Title"] = "Skapa ny fråga";
}

<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - STL Forum</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <style>
        .body2 {
            background-color: #f8f9fa;
            margin: 0;
            padding: 0;
        }

        .navbar {
            position: absolute !important;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            padding: 10px 20px !important;
            background: linear-gradient(180deg, rgba(7, 57, 105, 0.56) 0%, rgba(7, 57, 105, 0.18) 65%, rgba(7, 57, 105, 0) 100%);
            backdrop-filter: blur(3px);
        }

        .page-nav-controls {
            gap: 0.5rem;
        }

        .hero-image {
            background-image: url('@Url.Content("~/images/herobild.png")');            height: 50vh;
            background-position: center;
            background-repeat: no-repeat;
            background-size: cover;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            padding-top: 108px;
        }

        .hero-text {
            text-align: center;
            color: white;
            max-width: 800px;
            padding: 20px;
        }

        .hero-text h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        .hero-text h3 {
            font-size: 1.2rem;
            font-weight: 300;
        }

        .navbar-brand img {
            transition: transform 0.3s ease;
        }

        .navbar-brand:hover img {
            transform: scale(1.1);
        }

        .btn_red.tillbaka {
            background: transparent;
            border: none;
            padding: 10px 0;
            margin-bottom: 30px;
        }

        .btn_red.tillbaka span.icon {
            background: url('@Url.Content("~/images/tillbaka.png")') no-repeat;
            float: left;
            width: 20px;
            height: 20px;
            background-size: contain;
        }

        .tillbaka a {
            text-decoration: none;
            color: black;
            font-size: 1rem;
            padding-left: 1rem;
        }

        .tillbaka a:hover {
            color: #095EA9;
            text-decoration: underline;
        }

        .alert {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 1050;
            min-width: 300px;
        }

        @@media (max-width: 991.98px) {
            .navbar {
                position: absolute !important;
                background: linear-gradient(180deg, rgba(7, 57, 105, 0.72) 0%, rgba(7, 57, 105, 0.3) 65%, rgba(7, 57, 105, 0) 100%);
                backdrop-filter: blur(3px);
                padding: 10px 12px !important;
                align-items: flex-start !important;
                gap: 10px;
            }

            .page-nav-controls {
                width: 100%;
                display: flex;
                flex-wrap: wrap;
                justify-content: flex-end;
            }

            .page-nav-controls .btn {
                flex: 1 1 auto;
                min-width: 120px;
            }

            .hero-image {
                height: auto;
                min-height: 38vh;
                padding: 122px 14px 20px;
            }

            .hero-text {
                width: 100%;
                padding: 8px 4px;
            }

            .hero-text h1 {
                font-size: 1.65rem;
            }

            .hero-text h3 {
                font-size: 1rem;
            }

            .alert {
                left: 12px;
                right: 12px;
                top: 12px;
                min-width: 0;
            }
        }

        @@media (max-width: 575.98px) {
            .navbar-brand img {
                height: 42px;
            }
        }
    </style>
</head>
<body class="body2">

<!-- Success/Error Messages -->
@if (TempData["SuccessMessage"] != null)
{
<div class="alert alert-success alert-dismissible fade show" role="alert">
    @TempData["SuccessMessage"]
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
}

@if (TempData["ErrorMessage"] != null)
{
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    @TempData["ErrorMessage"]
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
}

<header>
    <!-- Navbar som ligger ovanpå hero-bilden -->
    <nav class="navbar navbar-light justify-content-between center-logo-navbar">
        <!-- Klickbar logga till vänster -->
        <a href="@Url.Action("Index", "Social")" class="navbar-brand">
            <img src="~/images/stl-loga.png" width="auto" height="50" alt="STL Logga">
        </a>

        <div class="d-flex align-items-center page-nav-controls">
            <a asp-controller="Home" asp-action="Profile" class="btn btn-outline-light btn-sm me-2">
                Min profil
            </a>
            <!-- Klickbar logga ut till höger -->
            <a href="@Url.Action("Logout", "Home")" class="btn btn-danger btn-sm">Sign out</a>
        </div>
    </nav>

    <!-- Hero sektion med bakgrundsbild -->
    <div class="hero-image">
        <div class="hero-text">
            <h1>Skapa ny fråga</h1>
            <h3>Utöka kunskapsbasen - din digitala vägvisare</h3>
        </div>
    </div>
</header>

<main>
    <div class="container mt-5">
        <!-- Tillbaka knapp -->
        <div class="btn btn_red tillbaka">
            <span class="icon"></span>
            <a href="@Url.Action("Index", "Social")">tillbaka</a>
        </div>

        <!-- Create Question Form -->
        <form asp-controller="Social" asp-action="CreateQuestion" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="mb-4">
                <h4>Hjälp dig själv och andra!</h4>
                <p>Skapa en fråga så du underlättar för andra som stöter på samma problem.</p>
            </div>
            
            <div class="form-group mb-3">
                <label for="category" class="form-label">Kategori</label>
                <select class="form-control" id="category" name="category" required>
                    <option value="säljfråga">Säljfråga</option>
                    <option value="driftfråga">Driftfråga</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label for="title" class="form-label">Frågetitel</label>
                <input type="text"
                       class="form-control"
                       id="title"
                       name="title"
                       required
                       maxlength="200"
                       placeholder="Ange frågetitel">
            </div>

            <div class="form-group mb-3">
                <label for="content" class="form-label">Frågedetaljer</label>
                <textarea class="form-control"
                          id="content"
                          name="content"
                          rows="5"
                          required
                          placeholder="Beskriv din fråga här..."></textarea>
            </div>

            <div class="form-group mb-3">
                <label for="attachment" class="form-label">📎 Bilaga (valfritt)</label>
                <input type="file"
                       class="form-control"
                       id="attachment"
                       name="attachment"
                       accept=".pdf,.doc,.docx,.png,.jpg,.jpeg">
                <small class="form-text text-muted">Max 5MB. PDF, Word-dokument eller bilder tillåts.</small>
            </div>

            <button type="submit" class="btn btn-primary">Skapa fråga</button>
        </form>
    </div>
</main>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
