@model WebApplication2.Models.ContestLeaderboardViewModel
@{
    ViewData["Title"] = "Contest Leaderboard";
}

<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - STL Forum</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <style>
        .body2 {
            background-color: #f8f9fa;
            margin: 0;
            padding: 0;
        }

        .navbar {
            position: absolute !important;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            padding: 10px 20px !important;
            background: linear-gradient(180deg, rgba(7, 57, 105, 0.56) 0%, rgba(7, 57, 105, 0.18) 65%, rgba(7, 57, 105, 0) 100%);
            backdrop-filter: blur(3px);
        }

        .page-nav-controls {
            gap: 0.5rem;
        }

        .page-shell {
            padding-top: 86px;
        }

        @@media (max-width: 991.98px) {
            .navbar {
                position: absolute !important;
                background: linear-gradient(180deg, rgba(7, 57, 105, 0.72) 0%, rgba(7, 57, 105, 0.3) 65%, rgba(7, 57, 105, 0) 100%);
                backdrop-filter: blur(3px);
                padding: 10px 12px !important;
                align-items: flex-start !important;
                gap: 10px;
            }

            .page-nav-controls {
                width: 100%;
                display: flex;
                flex-wrap: wrap;
                justify-content: flex-end;
            }

            .page-nav-controls .btn {
                flex: 1 1 auto;
                min-width: 120px;
            }

            .page-shell {
                padding-top: 116px;
            }
        }

        @@media (max-width: 575.98px) {
            .navbar-brand img {
                height: 42px;
            }
        }
    </style>
</head>
<body class="body2">
<header>
    <nav class="navbar navbar-light justify-content-between center-logo-navbar">
        <a href="@Url.Action("Index", "Social")" class="navbar-brand">
            <img src="~/images/stl-loga.png" width="auto" height="50" alt="STL Logga">
        </a>
        <div class="d-flex align-items-center page-nav-controls">
            <a asp-controller="Home" asp-action="Profile" class="btn btn-outline-light btn-sm me-2">
                Min profil
            </a>
            <a href="@Url.Action("Logout", "Home")" class="btn btn-danger btn-sm">Sign out</a>
        </div>
    </nav>
</header>

<main class="container my-4 page-shell">
    <div class="mb-3">
        <a asp-controller="Social" asp-action="Index" class="btn btn-link text-decoration-none p-0">← Tillbaka</a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h2 class="mb-1">@Html.Raw(Model.Contest.Name)</h2>
            @if (!string.IsNullOrWhiteSpace(Model.Contest.Description))
            {
                <p class="text-muted mb-2">@Html.Raw(Model.Contest.Description)</p>
            }
            <small class="text-muted">
                @Model.Contest.StartDate.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("sv-SE"))
                -
                @Model.Contest.EndDate.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("sv-SE"))
            </small>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            @{
                var latestUpdated = Model.Entries.Any()
                    ? Model.Entries.Max(e => e.UpdatedDate)
                    : (DateTime?)null;
            }
            <h4 class="mb-3 d-flex justify-content-between align-items-center">
                <span>Full leaderboard</span>
                @if (latestUpdated.HasValue)
                {
                    <small class="text-muted">Uppdaterad: @latestUpdated.Value.ToString("yyyy-MM-dd HH:mm")</small>
                }
            </h4>
            @if (Model.Entries.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead>
                        <tr>
                            <th>#</th>
                            <th>Användare</th>
                            <th>Affärer</th>
                        </tr>
                        </thead>
                        <tbody>
                        @for (var i = 0; i < Model.Entries.Count; i++)
                        {
                            var entry = Model.Entries[i];
                            var rank = i + 1;
                            <tr>
                                <td>@rank</td>
                                <td>
                                    @if (rank == 1)
                                    {
                                        <span>🥇</span>
                                    }
                                    else if (rank == 2)
                                    {
                                        <span>🥈</span>
                                    }
                                    else if (rank == 3)
                                    {
                                        <span>🥉</span>
                                    }
                                    @(string.IsNullOrWhiteSpace(entry.DisplayName) ? entry.EmployeeNumber : entry.DisplayName)
                                </td>
                                <td><span class="badge bg-primary">@entry.DealsCount</span></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">Inga registrerade affärer inom tävlingens period ännu.</p>
            }
        </div>
    </div>
</main>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
